e<span class=\"token punctuation\">.</span>exports <span class=\"token operator\">=</span> <span class=\"token function\">main</span><span class=\"token punctuation\">(</span><span class=\"token punctuation\">)</span></code></pre></div>\n<h2>Quick Setup</h2>\n<p>Assumes script location <code class=\"language-text\">scripts/node-tooling-check.js</code></p>\n<div class=\"gatsby-highlight\" data-language=\"bash\"><pre class=\"language-bash\"><code class=\"language-bash\"><span class=\"token function\">npm</span> <span class=\"token function\">install</span> -D husky\n\n<span class=\"token builtin class-name\">echo</span> <span class=\"token string\">'{\n    \"hooks\": {\n      \"pre-push\": \"node scripts/node-tooling-check.js\"\n  }\n}\n'</span> <span class=\"token operator\">></span> .huskyrc</code></pre></div>","frontmatter":{"title":"Asdf and Nvm Check","date":"May 18, 2021","description":"Compare nvm and asdf node versions"}}},"pageContext":{"slug":"/2021-05-18-05-12-asdf-and-nvm-check/","previous":{"fields":{"slug":"/2021-05-16-14-05-proptypes-from-json/"},"frontmatter":{"title":"Proptypes from Json","draft":null}},"next":{"fields":{"slug":"/2021-05-23-20-01-deep-addressing-with-lodash/"},"frontmatter":{"title":"Deep Addressing with Lodash","draft":null}}}}}